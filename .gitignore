# ========================================
# CMake & Build Directories
# ========================================
# Ignores any folder starting with "build" anywhere in the project
build/
build-*/
out/
bin/

# ========================================
# Qt Creator & IDE Files
# ========================================
*.user
*.user.*
CMakeLists.txt.user*
.vscode/
.idea/
.env

# ========================================
# C++ & Qt Generated Artifacts
# ========================================
# Compiled object files
*.o
*.obj

# Qt Meta-Object Compiler and UI generated files
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h

# Makefiles generated by CMake
Makefile
Makefile.*
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
compile_commands.json

# ========================================
# macOS Specific
# ========================================
.DS_Store
.AppleDouble
.LSOverride

# ========================================
# Compiled Libraries & Executables
# ========================================
*.dylib
*.so
*.a
*.exe
*.app/
*.idx

# (Optional) If your executables end up in the root directory instead of the build folder, 
# you can explicitly ignore them by uncommenting the lines below:
# backend
# ApolloBackend
